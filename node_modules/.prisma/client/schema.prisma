generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CLIENTE
  ADMINISTRADOR
  OPERADOR
}

enum StatusPedido {
  AGUARDANDO_PAGAMENTO
  PAGO
  CANCELADO
}

model Usuario {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique @default(uuid()) @db.Uuid
  nome      String
  email     String   @unique
  cpf       String   @unique
  senha     String
  role      Role     @default(CLIENTE)
  unidadeId Int?
  unidade   Unidade? @relation(fields: [unidadeId], references: [id])
  pedidos   Pedido[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("usuarios")
}

model Unidade {
  id        Int              @id @default(autoincrement())
  uuid      String           @unique @default(uuid()) @db.Uuid
  nome      String
  endereco  String
  usuarios  Usuario[]
  estoques  EstoqueUnidade[]
  pedidos   Pedido[]
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@map("unidades")
}

model Produto {
  id        Int              @id @default(autoincrement())
  uuid      String           @unique @default(uuid()) @db.Uuid
  nome      String
  preco     Decimal          @db.Decimal(10, 2)
  estoques  EstoqueUnidade[]
  itens     ItemPedido[]
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@map("produtos")
}

model EstoqueUnidade {
  id        Int     @id @default(autoincrement())
  produtoId Int
  unidadeId Int
  saldo     Int     @default(0)
  produto   Produto @relation(fields: [produtoId], references: [id], onDelete: Restrict)
  unidade   Unidade @relation(fields: [unidadeId], references: [id], onDelete: Restrict)

  @@unique([produtoId, unidadeId])
  @@index([unidadeId])
  @@map("estoque_unidade")
}

model Pedido {
  id        Int          @id @default(autoincrement())
  uuid      String       @unique @default(uuid()) @db.Uuid
  usuarioId Int
  unidadeId Int
  status    StatusPedido @default(AGUARDANDO_PAGAMENTO)
  total     Decimal      @db.Decimal(10, 2)
  usuario   Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  unidade   Unidade      @relation(fields: [unidadeId], references: [id], onDelete: Restrict)
  itens     ItemPedido[]
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@map("pedidos")
}

model ItemPedido {
  id            Int     @id @default(autoincrement())
  pedidoId      Int
  produtoId     Int
  quantidade    Int
  precoUnitario Decimal @db.Decimal(10, 2)
  pedido        Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produto       Produto @relation(fields: [produtoId], references: [id], onDelete: Restrict)

  @@map("itens_pedido")
}
